{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@screens/*": ["src/screens/*"],
      "@components/*": ["src/components/*"],
      "@theme/*": ["src/theme/*"],
      "@db/*": ["src/db/*"],
      "@ml/*": ["src/ml/*"],
      "@i18n/*": ["src/i18n/*"],
      "@navigation/*": ["src/navigation/*"],
      "@services/*": ["src/services/*"]
    }
  }
}
